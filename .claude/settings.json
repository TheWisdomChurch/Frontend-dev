{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint src --cache --cache-location .cache/eslint/ --max-warnings 0 2>/dev/null || true",
            "statusMessage": "Running ESLint on staged changes...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
