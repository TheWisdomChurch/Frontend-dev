# Frontend API settings
# Leave NEXT_PUBLIC_API_URL / NEXT_PUBLIC_BACKEND_URL empty to use same-origin /api/v1 in browser.
# Configure API_PROXY_TARGET on the Next.js server for rewrite proxying.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_URL=
API_PROXY_TARGET=https://api.wisdomchurchhq.org
NEXT_PUBLIC_TESTIMONIAL_FORM_URL=https://admin.wisdomchurchhq.org/forms/share-testimony
NEXT_PUBLIC_META_PIXEL_ID=1283210753679058

# Media optimization pipeline
MEDIA_SOURCE_DIR=public
MEDIA_OUTPUT_DIR=public/_optimized
MEDIA_MANIFEST_PATH=public/_optimized/manifest.json
MEDIA_IMAGE_WEBP_QUALITY=78
MEDIA_IMAGE_WIDTHS=480,768,1280,1920
MEDIA_VIDEO_WEBM_CRF=34
# Optional: absolute ffmpeg path if ffmpeg is not on PATH
# FFMPEG_PATH=/usr/bin/ffmpeg
